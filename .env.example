# --- Database ---
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/ragdoc

# --- Queue ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# --- Models ---
# bge-m3: 1024-dim, multilingual, runs on CPU (slowly). On GPU, bump to a bigger model.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- LLM (Ollama) ---
# Default local model. On a machine with a GPU + 16GB you can switch to gpt-oss:20b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# --- Retrieval knobs ---
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CHUNK_TARGET_TOKENS=400
